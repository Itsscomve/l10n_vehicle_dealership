<odoo>
    <record id="view_production_lot_form_vehicle_trade" model="ir.ui.view">
        <field name="name">stock.lot.form.vehicle.trade</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.view_production_lot_form" />
        <field name="arch" type="xml">
            <xpath expr="//group[@name='main_group']/group[1]/field[@name='ref']" position="after">
                <field name="body_serial" />
                <field name="engine_serial" />
                <field name="vehicle_plate" />
            </xpath>
        </field>
    </record>

    <record id="view_production_lot_tree_vehicle_trade" model="ir.ui.view">
        <field name="name">stock.lot.list.vehicle.trade</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.view_production_lot_tree" />
        <field name="arch" type="xml">
            <xpath expr="//list/field[@name='ref']" position="after">
                <field name="body_serial" optional="hide" />
                <field name="engine_serial" optional="hide" />
                <field name="vehicle_plate" optional="show" />
            </xpath>
        </field>
    </record>
</odoo>
